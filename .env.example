# =============================================
# PriceControl Pro — Variables de Entorno
# =============================================
# Copiar este archivo como .env y llenar los valores reales.
# NUNCA commitear el archivo .env real.

# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...tu-anon-key

# API Base URL
VITE_API_URL=http://localhost:3000/api

# Servidor de actualizaciones (IP de red local o URL)
VITE_UPDATE_SERVER_URL=http://192.168.1.100:5173

# Contraseña maestra de acceso (cambiar en producción)
VITE_MASTER_PASSWORD=admin2026

# Feature Flags (override via env)
VITE_FLAG_DARK_MODE=false
VITE_FLAG_ADVANCED_ANALYTICS=false
VITE_FLAG_EXPORT_PDF=false

# Deploy Target (vercel | netlify | docker)
VITE_DEPLOY_TARGET=vercel

# App Version (inyectada por CI/CD)
VITE_APP_VERSION=5.0.0
