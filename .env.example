# =============================================
# Dulce Placer ERP — Variables de Entorno
# =============================================
# Copiar este archivo como .env y llenar los valores reales.
# NUNCA commitear el archivo .env real.

# ── FIREBASE (Sincronización entre dispositivos) ──────────────────
# Obtener desde: console.firebase.google.com → Tu proyecto → Configuración → Apps web
VITE_FIREBASE_API_KEY=AIzaSy...tu-api-key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456:web:abcdef

# ── APP CONFIG ────────────────────────────────────────────────────
# Contraseña maestra de acceso (cambiar en producción)
VITE_MASTER_PASSWORD=admin2026

# Deploy Target (vercel | netlify | docker)
VITE_DEPLOY_TARGET=vercel

# App Version (inyectada por CI/CD)
VITE_APP_VERSION=5.3.0

# ── FEATURE FLAGS (opcional) ──────────────────────────────────────
VITE_FLAG_DARK_MODE=false
VITE_FLAG_ADVANCED_ANALYTICS=false
VITE_FLAG_EXPORT_PDF=false
