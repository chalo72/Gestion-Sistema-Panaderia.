{
  "name": "dulce-placer-erp",
  "private": true,
  "version": "5.1.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite build && electron .",
    "update-version": "node scripts/update-version.js",
    "verify-integrity": "node scripts/verify-integrity.js",
    "build": "npm run test:proteccion && npm run update-version && vite build",
    "build:safe": "npm run test && npm run update-version && vite build",
    "test:proteccion": "vitest run src/lib/proteccion-tipos.test.ts src/lib/proveedores-productos.test.ts src/lib/integridad-codigo.test.ts --reporter=verbose",
    "build:electron": "npm run update-version && tsc -b && vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:login": "playwright test e2e/login.spec.ts",
    "test:e2e:ventas": "playwright test e2e/ventas.spec.ts",
    "test:e2e:inventario": "playwright test e2e/inventario.spec.ts",
    "test:e2e:busqueda": "playwright test e2e/busqueda-rapida.spec.ts",
    "test:e2e:roles": "playwright test e2e/navegacion-roles.spec.ts",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173",
    "host": "vite --host 0.0.0.0"
  },
  "main": "electron/main.js",
  "dependencies": {
